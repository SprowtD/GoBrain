# Copy to .env for local dev:  cp .env.example .env
# .env is gitignored. In production (Railway) set these as service variables instead.

# --- core ---
DB_PATH=./data/jobs.db
VAULT_PATH=./data/vault
BACKEND_URL=http://localhost:8080
PORT=8080
# One-click bootstrap: set on first deploy to auto-mint an admin token (printed
# to the logs once). Unset after you've captured it. Leave blank for local dev
# and use `go run ./cmd/server mint "my phone"` instead.
# BOOTSTRAP_ADMIN_LABEL=

# --- LLM chunking (OpenRouter) ---
# Get a key at https://openrouter.ai/keys — starts with "sk-or-...".
# Leave OPENROUTER_API_KEY blank to run offline (files one raw chunk per capture).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# Vision model for image OCR (must be a real OpenRouter slug — check openrouter.ai/models).
# gpt-4o-mini is multimodal, so it can serve both. Gemini option: google/gemini-2.5-flash
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini
# Embedding model for semantic search + related notes (OpenRouter /embeddings).
# Uses the same OPENROUTER_API_KEY. If the key is blank, search falls back to keyword.
OPENROUTER_EMBEDDING_MODEL=qwen/qwen3-embedding-8b
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- vault git sync (optional; commits stay local if unset) ---
# VAULT_REPO_URL=git@github.com:you/second-brain.git
# GIT_SSH_KEY=
# GIT_AUTHOR_NAME=secondbrain
# GIT_AUTHOR_EMAIL=secondbrain@localhost
